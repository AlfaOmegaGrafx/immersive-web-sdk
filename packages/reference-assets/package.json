{
  "name": "@iwsdk/reference-assets",
  "version": "0.3.1",
  "description": "Producer pipeline and versioned corpus payloads for @iwsdk/reference",
  "private": false,
  "type": "module",
  "scripts": {
    "build:tools": "tsc -p tsconfig.tools.json",
    "ingest": "npm run build:tools && node dist-tools/tools/ingest.js",
    "build:payload": "pnpm run ingest && pnpm run build && pnpm run build:model",
    "build": "node ./scripts/build-assets.mjs",
    "build:model": "node ./scripts/build-model.mjs",
    "build:if-ready": "node ./scripts/build-assets.mjs --if-ready",
    "build:model:if-ready": "node ./scripts/build-model.mjs --if-ready",
    "prepare": "pnpm run build:if-ready",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/facebook/immersive-web-sdk.git",
    "directory": "packages/reference-assets"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@huggingface/transformers": "^3.1.2",
    "@types/node": "^20.11.0",
    "glob": "^12.0.0",
    "tar": "^7.5.13",
    "ts-morph": "^27.0.2",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
